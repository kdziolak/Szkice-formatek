        <mxCell id="subtitle" value="Kolory, kształty i oznaczenia wspólne dla wszystkich stron diagramu." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontColor=#475569;" vertex="1" parent="1"><mxGeometry x="40" y="58" width="680" height="20" as="geometry"/></mxCell>
        <mxCell id="l1" value="Użytkownik / rola biznesowa" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="80" y="120" width="170" height="70" as="geometry"/></mxCell>
        <mxCell id="l2" value="Czynność użytkownika" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="320" y="120" width="170" height="70" as="geometry"/></mxCell>
        <mxCell id="l3" value="Automatyczna akcja systemu" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="560" y="120" width="180" height="70" as="geometry"/></mxCell>
        <mxCell id="l4" value="Decyzja / bramka" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="820" y="110" width="160" height="90" as="geometry"/></mxCell>
        <mxCell id="l5" value="Rejestr / dane" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1"><mxGeometry x="1060" y="110" width="140" height="90" as="geometry"/></mxCell>
        <mxCell id="l6" value="Błąd / wyjątek" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1"><mxGeometry x="1280" y="120" width="160" height="70" as="geometry"/></mxCell>
        <mxCell id="l7" value="Zakończenie procesu" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b7e1cd;strokeColor=#2d7600;" vertex="1" parent="1"><mxGeometry x="80" y="250" width="170" height="70" as="geometry"/></mxCell>
        <mxCell id="l8" value="Formularz / dokument" style="shape=mxgraph.flowchart.document;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="320" y="240" width="150" height="90" as="geometry"/></mxCell>
        <mxCell id="text1" value="Konwencje&#xa;1. Etykiety są zapisane po polsku.&#xa;2. Procesy pokazują odpowiedzialność użytkownika i systemu.&#xa;3. Cylindry oznaczają rejestry, historię lub słowniki.&#xa;4. Kolor czerwony oznacza wyjątek lub blokadę.&#xa;5. Kolor ciemnozielony oznacza wynik końcowy." style="text;html=1;strokeColor=#cbd5e1;fillColor=#ffffff;align=left;verticalAlign=top;spacing=8;fontSize=13;fontColor=#0f172a;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="560" y="240" width="420" height="170" as="geometry"/></mxCell>
        <mxCell id="text2" value="Oznaczenia projektowe&#xa;- [ZAŁOŻENIE] = element nieopisany literalnie w pliku TXT, ale potrzebny do spójnego projektu procesu.&#xa;- Statusy z TXT mają wyższy priorytet niż statusy pomocnicze.&#xa;- Macierz UC wskazuje, gdzie przypadek użycia jest pokazany wprost, a gdzie tylko częściowo." style="text;html=1;strokeColor=#cbd5e1;fillColor=#ffffff;align=left;verticalAlign=top;spacing=8;fontSize=13;fontColor=#0f172a;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="1020" y="240" width="440" height="170" as="geometry"/></mxCell>
      </root>
