  <diagram id="scpr-matrix" name="09 Macierz UC">
    <mxGraphModel dx="1600" dy="1200" grid="1" gridSize="8" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1200" math="0" shadow="0" background="#f8fafc">
